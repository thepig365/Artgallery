# ─────────────────────────────────────────────────────────────
# Art Valuation Protocol — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# Supabase / PostgreSQL connection string
# Get this from: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Node environment
NODE_ENV="development"

# Public site URL (used for canonical URLs, sitemap, OpenGraph, robots.txt)
# Production: https://gallery.bayviewhub.me — fallback in code when unset
# Include https:// or the code will prepend it
NEXT_PUBLIC_SITE_URL="https://gallery.bayviewhub.me"

# Admin notification (new artist submissions)
# Get API key from https://resend.com — free tier allows 100 emails/day
RESEND_API_KEY="re_xxxxxxxxxxxx"
ADMIN_EMAIL="admin@yourdomain.com"
# Optional: custom sender (default: Art Gallery <onboarding@resend.dev> for testing)
# EMAIL_FROM="Art Gallery <noreply@yourdomain.com>"

# Public contact email (privacy, terms, portal, submit)
# Used in footer links, legal pages, and contact forms
NEXT_PUBLIC_CONTACT_EMAIL="gallery@bayviewhub.me"
