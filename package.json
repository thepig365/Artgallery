{
  "name": "artgallery-tmp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "db:migrate": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "guard:db": "node scripts/guardrails/db-change-check.mjs",
    "guard:db:staged": "node scripts/guardrails/db-change-check.mjs --staged",
    "harvest:curated": "npx tsx scripts/harvest_curated_masterpieces.ts",
    "harvest:top50": "npx tsx scripts/harvest_curated_masterpieces.ts --maxArtists=10 --perArtist=6",
    "harvest:zeros": "npx tsx scripts/harvest_zeros.ts",
    "harvest:daily": "npx tsx scripts/harvest_curated_masterpieces.ts --maxArtists=5 --perArtist=3 --sources=both"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "cheerio": "^1.2.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "14.2.35",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
